# ============================================================
# UMaT Postgrad Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# ── Server ──
PORT=5000
NODE_ENV=development

# ── PostgreSQL Database (Neon) ──
# Use the POOLED connection string from Neon dashboard (hostname contains "-pooler")
# It must end with ?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── JWT Authentication ──
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=24h

# ── Chatbot / AI Gateway ──
# The chatbot runs as a separate service but can optionally be proxied
# through this backend. Set CHATBOT_SERVICE_URL to the chatbot's address.
#
# Option A: Chatbot runs as a standalone service (recommended for production)
CHATBOT_SERVICE_URL=http://localhost:5001
#
# Option B: Use an AI gateway directly (e.g., OpenAI, Gemini)
# AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1/chat/completions
# AI_GATEWAY_API_KEY=your_ai_gateway_key
#
# The frontend should point to:
#   VITE_API_URL=http://localhost:5000/api  (this backend)
#   VITE_CHATBOT_URL=http://localhost:5001  (or http://localhost:5000/api/chatbot if proxied)

# ── File Uploads (Cloudinary — required in production) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
MAX_FILE_SIZE_MB=50

# ── Local uploads fallback (development only) ──
UPLOAD_DIR=./uploads

# ── CORS ──
# Production: set to your Vercel frontend URL
# CORS_ORIGINS=https://your-app.vercel.app
# Development:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend Config (for reference — set these in Vercel environment variables) ──
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
# VITE_CHATBOT_URL=https://your-chatbot.onrender.com
